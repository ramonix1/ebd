<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
      <div>
        <h1 class="d-flex align-items-center gap-3 mb-0">
          <img src="/images/logo.jpeg" alt="Logo" style="height: 40px;">
          Dashboard Professor
        </h1>
      </div>
      <img src="/images/logo_claro.jpeg" alt="Logo" style="height: 80px; opacity: 0.8;">
    </div>
  </div>

  <!-- ALERTA DE DOMINGO -->
  <% if (stats.isDomingo && !stats.chamadaHojeRegistrada) { %>
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-circle"></i>
      <strong>Atenção!</strong> Hoje é domingo e você ainda não registrou a chamada das suas turmas.
      <a href="/professor/minhas-turmas" class="alert-link">Clique aqui para registrar agora</a>.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- CARDS PRINCIPAIS -->
  <div class="row mb-4">
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="text-muted small mb-1">Minhas Turmas</p>
              <h3 class="mb-0"><%= stats.turmas %></h3>
            </div>
            <i class="bi bi-buildings text-primary" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="text-muted small mb-1">Total de Alunos</p>
              <h3 class="mb-0"><%= stats.alunos %></h3>
            </div>
            <i class="bi bi-people text-success" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="text-muted small mb-1">Frequência Média</p>
              <h3 class="mb-0"><%= stats.frequencia %>%</h3>
            </div>
            <i class="bi bi-graph-up text-warning" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CARD DA ÚLTIMA CHAMADA -->
  <div class="row mb-4">
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="text-muted small mb-1">Última Chamada Registrada</p>
              <% if (stats.ultimaChamada) { %>
                <h5 class="mb-0 text-success">
                  <%= new Date(stats.ultimaChamada).toLocaleDateString('pt-BR') %>
                </h5>
              <% } else { %>
                <h5 class="mb-0 text-muted">Nenhuma registrada</h5>
              <% } %>
            </div>
            <i class="bi bi-calendar-check text-info" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ATALHOS RÁPIDOS -->
  <div class="row">
    <div class="col-lg-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom">
          <h5 class="mb-0">
            <i class="bi bi-activity"></i> Atalhos Rápidos
          </h5>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <a href="/professor/minhas-turmas" class="btn btn-outline-primary btn-lg w-100 mb-3">
                <i class="bi bi-buildings"></i> Minhas Turmas
              </a>
            </div>
            <div class="col-md-6">
              <a href="/professor/minhas-turmas" class="btn btn-outline-success btn-lg w-100 mb-3">
                <i class="bi bi-check2-square"></i> Registrar Frequência
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
