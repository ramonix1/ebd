<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12">
      <h1>
        <i class="bi bi-buildings"></i> Minhas Turmas
      </h1>
    </div>
  </div>

  <% if (turmas && turmas.length > 0) { %>
    <div class="row">
      <% turmas.forEach(turma => { %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-primary text-white">
              <h5 class="mb-0">
                <i class="bi bi-book"></i> <%= turma.nome %>
              </h5>
            </div>
            <div class="card-body">
              <p class="text-muted small mb-2">
                <i class="bi bi-calendar"></i> <%= turma.dia_semana %> · <%= turma.horario_inicio %> às <%= turma.horario_fim %>
              </p>
              <p class="text-muted small mb-3">
                <i class="bi bi-people"></i> <%= turma.total_alunos %> aluno(s)
              </p>
              <p class="small">
                <span class="badge bg-info"><%= turma.trimestre %>º Trimestre <%= turma.ano_letivo %></span>
              </p>
            </div>
            <div class="card-footer bg-light">
              <div class="d-grid gap-2">
                <a href="/professor/turma/<%= turma.id %>/alunos" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-people"></i> Ver Alunos
                </a>
                <a href="/professor/turma/<%= turma.id %>/frequencia" class="btn btn-sm btn-outline-info">
                  <i class="bi bi-graph-up"></i> Ver Frequência
                </a>
                <a href="/professor/turma/<%= turma.id %>/frequencia/registrar" class="btn btn-sm btn-success">
                  <i class="bi bi-check2-square"></i> Registrar Aula
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="alert alert-warning" role="alert">
      <i class="bi bi-exclamation-triangle"></i> Você não está vinculado a nenhuma turma ainda.
    </div>
  <% } %>

  <div class="alert alert-info" role="alert">
    <i class="bi bi-lightbulb"></i>
    <strong>Dica:</strong> Para cada turma você pode:
    <ul class="mb-0 mt-2">
      <li><strong>Ver Alunos:</strong> Visualize todos os alunos matriculados</li>
      <li><strong>Registrar Frequência:</strong> Registre presença/ausência dos alunos</li>
      <li><strong>Ver Frequência:</strong> Veja o relatório de presença com percentuais</li>
    </ul>
  </div>
</div>

<%- include('../partials/footer') %>
