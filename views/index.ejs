<%- include('partials/header') %>

<div class="container-fluid bg-light min-vh-100">
  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="display-4 fw-bold mb-4">
          <i class="bi bi-book text-primary"></i> Bem-vindo ao EBD
        </h1>
        <p class="lead mb-4">
          Sistema de gestão completo para Escola Bíblica Dominical. Gerencie turmas, alunos,
          frequência e matrículas de forma simples e eficiente.
        </p>

        <div class="row mb-4">
          <div class="col-md-6">
            <div class="card border-0 shadow-sm mb-3">
              <div class="card-body">
                <i class="bi bi-buildings text-primary" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-3">Gestão de Turmas</h5>
                <p class="card-text small text-muted">Organize suas turmas por faixa etária e trimestre</p>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card border-0 shadow-sm mb-3">
              <div class="card-body">
                <i class="bi bi-people text-success" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-3">Gestão de Alunos</h5>
                <p class="card-text small text-muted">Controle matrículas e dados dos alunos</p>
              </div>
            </div>
          </div>
        </div>

        <div class="row mb-4">
          <div class="col-md-6">
            <div class="card border-0 shadow-sm">
              <div class="card-body">
                <i class="bi bi-check2-square text-info" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-3">Controle de Frequência</h5>
                <p class="card-text small text-muted">Registre presença em cada aula</p>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card border-0 shadow-sm">
              <div class="card-body">
                <i class="bi bi-graph-up text-warning" style="font-size: 2rem;"></i>
                <h5 class="card-title mt-3">Relatórios</h5>
                <p class="card-text small text-muted">Gere relatórios detalhados de frequência</p>
              </div>
            </div>
          </div>
        </div>

        <a href="/login" class="btn btn-primary btn-lg">
          <i class="bi bi-box-arrow-in-right"></i> Acessar Sistema
        </a>
      </div>

      <div class="col-lg-6 text-center">
        <i class="bi bi-book" style="font-size: 150px; color: #0d6efd; opacity: 0.1;"></i>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
