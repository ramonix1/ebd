<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12">
      <h1>
        <i class="bi bi-person-circle"></i> Meu Perfil
      </h1>
    </div>
  </div>

  <% if (typeof sucesso !== 'undefined' && sucesso) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle"></i> Perfil atualizado com sucesso!
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <div class="row">
    <!-- Coluna Esquerda: Foto de Perfil -->
    <div class="col-lg-4 mb-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center p-5">
          <div class="mb-4">
            <% if (usuario.foto_perfil) { %>
              <img src="<%= usuario.foto_perfil %>" alt="Foto de Perfil" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover; border: 3px solid #0d6efd;">
            <% } else { %>
              <div class="rounded-circle d-inline-flex align-items-center justify-content-center bg-light" style="width: 150px; height: 150px; border: 3px solid #dee2e6;">
                <i class="bi bi-person-fill" style="font-size: 3rem; color: #adb5bd;"></i>
              </div>
            <% } %>
          </div>

          <h5 class="card-title"><%= usuario.nome %></h5>
          <p class="text-muted small mb-3">
            <i class="bi bi-envelope"></i> <%= usuario.email %><br>
            <i class="bi bi-shield-check"></i>
            <% if (usuario.tipo === 'admin') { %>
              Administrador
            <% } else { %>
              Professor
            <% } %>
          </p>

          <form method="POST" action="/perfil" enctype="multipart/form-data" id="formFoto" class="mb-3">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <div class="mb-3">
              <label for="foto_perfil" class="form-label">
                <i class="bi bi-upload"></i> Foto de Perfil
              </label>
              <input
                type="file"
                class="form-control"
                id="foto_perfil"
                name="foto_perfil"
                accept="image/jpeg,image/png,image/gif"
                onchange="this.form.submit()"
              >
              <small class="text-muted d-block mt-2">
                Máximo 5MB. Formatos: JPEG, PNG, GIF
              </small>
            </div>
          </form>

          <% if (usuario.foto_perfil) { %>
            <form method="POST" action="/perfil/deletar-foto" style="display: inline;">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Tem certeza que deseja remover a foto?');">
                <i class="bi bi-trash"></i> Remover Foto
              </button>
            </form>
          <% } %>

          <hr>

          <p class="text-muted small mb-0">
            <i class="bi bi-calendar"></i> Membro desde <%= new Date(usuario.criado_em).toLocaleDateString('pt-BR') %>
          </p>
        </div>
      </div>
    </div>

    <!-- Coluna Direita: Editar Dados -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">
            <i class="bi bi-pencil"></i> Editar Dados Pessoais
          </h5>
        </div>
        <div class="card-body">
          <form method="POST" action="/perfil" autocomplete="off">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <div class="mb-4">
              <label for="nome" class="form-label">
                Nome
                <span class="required-indicator">*</span>
              </label>
              <input
                type="text"
                class="form-control form-control-lg"
                id="nome"
                name="nome"
                value="<%= usuario.nome %>"
                required
              >
            </div>

            <div class="mb-4">
              <label for="email" class="form-label">
                Email (Não pode ser alterado)
              </label>
              <input
                type="email"
                class="form-control form-control-lg"
                id="email"
                value="<%= usuario.email %>"
                disabled
              >
              <small class="text-muted d-block mt-2">
                Para alterar o email, entre em contato com o administrador
              </small>
            </div>

            <div class="mb-4">
              <label for="tipo" class="form-label">
                Tipo de Usuário
              </label>
              <input
                type="text"
                class="form-control form-control-lg"
                value="<%= usuario.tipo === 'admin' ? 'Administrador' : 'Professor' %>"
                disabled
              >
            </div>

            <hr class="my-5">

            <div class="mb-4">
              <label for="senha" class="form-label">
                <i class="bi bi-lock"></i> Nova Senha (deixe em branco para não alterar)
              </label>
              <input
                type="password"
                class="form-control form-control-lg"
                id="senha"
                name="senha"
                autocomplete="new-password"
                placeholder="Deixe em branco para manter a senha atual"
              >
              <small class="text-muted d-block mt-2">
                Mínimo recomendado: 8 caracteres com números e símbolos
              </small>
            </div>

            <div class="mb-4">
              <label for="senha_confirmacao" class="form-label">
                Confirmar Nova Senha
              </label>
              <input
                type="password"
                class="form-control form-control-lg"
                id="senha_confirmacao"
                placeholder="Confirme a nova senha"
              >
              <small class="text-muted d-block mt-2">
                Se você mudou a senha, confirme aqui
              </small>
            </div>

            <div class="d-flex gap-3">
              <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-check-circle"></i> Salvar Alterações
              </button>
              <a href="/admin/dashboard" class="btn btn-secondary btn-lg">
                <i class="bi bi-arrow-left"></i> Voltar
              </a>
            </div>
          </form>
        </div>
      </div>

      <!-- Dica -->
      <div class="alert alert-info mt-4" role="alert">
        <i class="bi bi-lightbulb"></i>
        <strong>Dica:</strong> Sua foto de perfil será útil para futuras funcionalidades do sistema. Escolha uma foto clara e profissional!
      </div>
    </div>
  </div>
</div>

<script>
  // Validar correspondência de senhas
  document.querySelector('form').addEventListener('submit', function(e) {
    const senha = document.getElementById('senha').value;
    const confirmacao = document.getElementById('senha_confirmacao').value;

    if (senha && senha !== confirmacao) {
      e.preventDefault();
      alert('As senhas não conferem!');
      return false;
    }
  });
</script>

<%- include('../partials/footer') %>
