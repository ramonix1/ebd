<%- include('partials/header') %>

<div class="container-fluid bg-light min-vh-100 d-flex align-items-center">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0">
          <div class="card-body p-5">
            <div class="text-center mb-4">
              <img src="/images/logo_com_letras_claro.jpeg" alt="EBD Logo" style="height: 70px; margin-bottom: 1rem; max-width: 100%;">
              <p class="text-muted small">Sistema de Gestão para Escola Bíblica Dominical</p>
            </div>

            <% if (typeof erro !== 'undefined' && erro) { %>
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle"></i> <%= erro %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <form method="POST" action="/login" autocomplete="off">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <div class="mb-3">
                <label for="email" class="form-label">
                  <i class="bi bi-envelope"></i> Email
                </label>
                <input
                  type="email"
                  class="form-control form-control-lg"
                  id="email"
                  name="email"
                  placeholder="seu@email.com"
                  autocomplete="username"
                  required
                  autofocus
                >
              </div>

              <div class="mb-4">
                <label for="senha" class="form-label">
                  <i class="bi bi-lock"></i> Senha
                </label>
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="senha"
                  name="senha"
                  placeholder="Sua senha"
                  autocomplete="current-password"
                  required
                >
              </div>

              <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-box-arrow-in-right"></i> Entrar
              </button>
            </form>

            <hr class="my-4">

            <p class="text-center text-muted small">
              <i class="bi bi-info-circle"></i>
              Sistema de gestão para Escola Bíblica Dominical
            </p>
          </div>
        </div>

        <div class="alert alert-info mt-4" role="alert">
          <small>
            <i class="bi bi-question-circle"></i>
            Para suporte, entre em contato com o administrador do sistema.
          </small>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
