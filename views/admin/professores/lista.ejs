<%- include('../../partials/header') %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
      <h1>
        <i class="bi bi-person-check"></i> Professores
      </h1>
      <a href="/admin/professores/novo" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Novo Professor
      </a>
    </div>
  </div>

  <% if (typeof sucesso !== 'undefined' && sucesso) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle"></i> Operação realizada com sucesso!
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm">
    <% if (professores && professores.length > 0) { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead class="bg-light">
            <tr>
              <th>Nome</th>
              <th>Email</th>
              <th>Turmas</th>
              <th>Status</th>
              <th style="width: 200px;">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% professores.forEach(professor => { %>
              <tr>
                <td>
                  <strong><%= professor.nome %></strong>
                </td>
                <td>
                  <code><%= professor.email %></code>
                </td>
                <td>
                  <% if (professor.turmas_nomes) { %>
                    <% professor.turmas_nomes.split(', ').forEach(turma => { %>
                      <span class="badge bg-info"><%= turma %></span>
                    <% }); %>
                  <% } else { %>
                    <small class="text-muted">Nenhuma turma</small>
                  <% } %>
                </td>
                <td>
                  <% if (professor.ativo) { %>
                    <span class="badge bg-success">
                      <i class="bi bi-check-circle"></i> Ativo
                    </span>
                  <% } else { %>
                    <span class="badge bg-secondary">
                      <i class="bi bi-x-circle"></i> Inativo
                    </span>
                  <% } %>
                </td>
                <td>
                  <a href="/admin/professores/<%= professor.id %>/editar" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <form method="POST" action="/admin/professores/<%= professor.id %>/deletar" style="display: inline;" onsubmit="return confirm('Tem certeza? Isto removerá o professor de todas as turmas.');">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="card-body">
        <p class="text-muted text-center py-5">
          <i class="bi bi-inbox" style="font-size: 3rem;"></i>
          <br>
          Nenhum professor cadastrado ainda.
        </p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../../partials/footer') %>
