<%- include('../../partials/header') %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
      <h1>
        <i class="bi bi-buildings"></i> Turmas
      </h1>
      <a href="/admin/turmas/novo" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nova Turma
      </a>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <% if (turmas && turmas.length > 0) { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead class="bg-light">
            <tr>
              <th>Nome</th>
              <th>Faixa Etária</th>
              <th>Horário</th>
              <th>Trimestre</th>
              <th>Professores</th>
              <th style="width: 150px;">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% turmas.forEach(turma => { %>
              <tr>
                <td>
                  <strong><%= turma.nome %></strong>
                </td>
                <td>
                  <% if (turma.faixa_etaria) { %>
                    <%= turma.faixa_etaria %>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
                <td>
                  <i class="bi bi-clock"></i>
                  <%= turma.horario_inicio %> às <%= turma.horario_fim %>
                </td>
                <td>
                  <%= turma.trimestre %>º trimestre
                </td>
                <td>
                  <% if (turma.professores_nomes) { %>
                    <small>
                      <% turma.professores_nomes.split(', ').forEach(prof => { %>
                        <span class="badge bg-info"><%= prof %></span>
                      <% }); %>
                    </small>
                  <% } else { %>
                    <small class="text-muted">Nenhum professor vinculado</small>
                  <% } %>
                </td>
                <td>
                  <a href="/admin/turmas/<%= turma.id %>/alunos" class="btn btn-sm btn-outline-secondary" title="Ver alunos">
                    <i class="bi bi-eye"></i> Ver
                  </a>
                  <a href="/admin/turmas/<%= turma.id %>/matriculas" class="btn btn-sm btn-outline-info" title="Gerenciar alunos">
                    <i class="bi bi-person-plus"></i> Matrículas
                  </a>
                  <a href="/admin/turmas/<%= turma.id %>/editar" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <form method="POST" action="/admin/turmas/<%= turma.id %>/deletar" style="display: inline;" onsubmit="return confirm('Tem certeza?');">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="card-body">
        <p class="text-muted text-center py-5">
          <i class="bi bi-inbox" style="font-size: 3rem;"></i>
          <br>
          Nenhuma turma cadastrada ainda.
        </p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../../partials/footer') %>
